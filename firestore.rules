rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 管理者かどうか判定する関数
    function isAdmin() {
      // ログイン済み かつ usersコレクションの 自分の役割が 'admin' であるか
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 自分のデータかどうか判定（ドキュメントに記録される uid フィールドと比較する場合）
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // 1. users コレクション
    // IDが自分のUIDと一致する場合は作成・読み書き可能。管理者はすべてのユーザー情報を読み書き可能。
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // 2. タイムシート申請 (timesheetRequests)
    match /timesheetRequests/{docId} {
      // 自分の申請だけ読み込みと作成ができる。管理者は全て読み書き可能
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if isAdmin();
    }

    // 3. 通所予定変更申請 (attendanceChangeRequests)
    match /attendanceChangeRequests/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if isAdmin();
    }

    // 4. 面談申請 (interviewRequests)
    match /interviewRequests/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if isAdmin();
    }

    // 5. 確定した面談 (interviews)
    // （スタッフ管理者が予定を設定するため、一般利用者は読み込みのみ）
    match /interviews/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }
    
    // 6. 確定したタイムシート (timesheets)
    match /timesheets/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }
  }
}

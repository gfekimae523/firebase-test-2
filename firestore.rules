rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 補助関数
    // ==========================================

    // ログイン済みか
    function isSignedIn() {
      return request.auth != null;
    }

    // 管理者かどうか判定
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 自分のデータかどうか（保存されているuidと一致するか）
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ==========================================
    // コレクション別ルール
    // ==========================================

    // 1. ユーザー情報 (users)
    match /users/{uid} {
      // 自分の情報の取得・更新。管理者は全ユーザー読み書き可能。
      allow read, update: if isOwner(uid) || isAdmin();
      // 新規登録時のみ誰でも（ログイン済みなら）作成可能
      allow create: if isOwner(uid);
      allow delete: if isAdmin();
    }

    // 2. お知らせ (announcements)
    match /announcements/{docId} {
      // 全員読み込み可能。管理者は投稿・編集・削除可能。
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3. タイムシート申請 (timesheetRequests)
    match /timesheetRequests/{docId} {
      // 自分の申請のみ。管理者は全て。
      allow read: if isOwner(resource.data.uid) || isAdmin();
      // 作成時に自分のUIDを指定しているかチェック。
      allow create: if isOwner(request.resource.data.uid);
      // 利用者による「取り下げ(cancelled)」更新を許可。それ以外は管理人のみ。
      allow update: if isOwner(resource.data.uid) && request.resource.data.status == 'cancelled' || isAdmin();
      allow delete: if isAdmin();
    }

    // 4. 通所予定変更申請 (attendanceChangeRequests)
    match /attendanceChangeRequests/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isOwner(resource.data.uid) && request.resource.data.status == 'cancelled' || isAdmin();
      allow delete: if isAdmin();
    }

    // 5. 面談申請 (interviewRequests)
    match /interviewRequests/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isOwner(resource.data.uid) && request.resource.data.status == 'cancelled' || isAdmin();
      allow delete: if isAdmin();
    }

    // 6. 確定したタイムシート (timesheets)
    // タイムシートに関連する詳細データ(attendances)も含む
    match /timesheets/{tsId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();

      // サブコレクション（各日付の勤怠レコード）
      match /attendances/{dateId} {
        allow read: if isOwner(get(/databases/$(database)/documents/timesheets/$(tsId)).data.uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // 7. 確定した面談 (interviews)
    match /interviews/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }
    
    // 8. 通知 (notifications) - 基本読み取り専用（作成はシステム/管理者が行う想定）
    match /notifications/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
